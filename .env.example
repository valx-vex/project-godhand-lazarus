# Lazarus MCP Server Configuration
# Copy this file to .env and adjust values for your setup

# Qdrant vector database connection
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Embedding model (sentence-transformers)
# Default: all-MiniLM-L6-v2 (384 dimensions, fast, CPU-friendly)
# LAZARUS_EMBED_MODEL=all-MiniLM-L6-v2

# --- Ingestion-specific settings ---

# OpenAI export file path (conversations.json from ChatGPT export)
LAZARUS_DATA_FILE=./data/conversations.json

# Collection name override (defaults vary per ingester)
# LAZARUS_COLLECTION=my_collection

# Gemini CLI session directory
# GEMINI_TMP_DIR=~/.gemini/tmp

# Codex CLI session directory
# CODEX_SESSIONS_DIR=~/.codex/sessions
