# Godhand Lazarus runtime configuration
# Copy to .env and adjust for your machine if needed.
# Do not place GEMINI_API_KEY here. Gemini stops at the first env file it finds,
# so use .gemini/.env via scripts/configure_gemini_auth.py instead.

# Qdrant vector database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Optional explicit repo root for daemon or wrappers
# LAZARUS_REPO_ROOT=/absolute/path/to/project-godhand-lazarus

# OpenAI export file path
LAZARUS_DATA_FILE=./data/conversations.json

# Optional collection override for custom imports
# LAZARUS_COLLECTION=my_collection

# Optional session roots
# GEMINI_TMP_DIR=~/.gemini/tmp
# CODEX_SESSIONS_DIR=~/.codex/sessions
